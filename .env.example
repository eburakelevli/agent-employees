DISCORD_BOT_TOKEN=your_discord_bot_token_here

# LLM provider: "openai", "claude", or "ollama"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (required if LLM_PROVIDER=claude)
# Models: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (required if LLM_PROVIDER=ollama)
# Run: ollama pull llama3.2  (or mistral, qwen2.5, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Workspace MCP (optional)
# Example server: local/remote streamable-http endpoint from a Workspace MCP server
GOOGLE_WORKSPACE_MCP_URL=
GOOGLE_WORKSPACE_MCP_BEARER_TOKEN=
GOOGLE_WORKSPACE_MCP_TIMEOUT_SECONDS=30
